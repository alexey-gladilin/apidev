"""Manual integration scaffold: map domain errors to transport payloads."""

from typing import Any


def map_error(error: Exception) -> dict[str, Any]:
    # TODO: replace with domain-specific mapping.
    if error.__class__.__name__ == "InvoiceNotFoundError":
        return {"code": "INVOICE_NOT_FOUND", "message": "Invoice not found"}

    return {
        "code": "INTERNAL_ERROR",
        "message": "Internal server error",
    }
