"""Manual integration scaffold: resolve auth dependencies by auth mode.

Supported auth modes from generated metadata: {{ supported_auth_modes_literal }}
"""

from typing import Any

DEFAULT_AUTH_MODE = {{ default_auth_mode_literal }}
BEARER_AUTH_MODE = {{ bearer_auth_mode_literal }}
SUPPORTED_AUTH_MODES = {{ supported_auth_modes_literal }}


def _normalize_auth_mode(raw_auth_mode: object) -> str:
    return str(raw_auth_mode).strip().lower()


def _canonicalize_auth_mode(raw_auth_mode: object) -> str:
    auth_mode = _normalize_auth_mode(raw_auth_mode)
    if auth_mode not in SUPPORTED_AUTH_MODES:
        raise ValueError(f"Unsupported auth mode: {auth_mode}")
    return auth_mode


def resolve_auth_dependency(auth_mode: str) -> Any:
    auth_mode = _canonicalize_auth_mode(auth_mode)
    if auth_mode == DEFAULT_AUTH_MODE:
        return None
    if auth_mode == BEARER_AUTH_MODE:
        # TODO: return your FastAPI dependency, e.g. require_bearer_user
        raise NotImplementedError("Configure bearer auth dependency.")
    raise ValueError(f"Unsupported auth mode: {auth_mode}")
