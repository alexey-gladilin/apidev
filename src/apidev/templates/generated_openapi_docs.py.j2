def _resolve_domain_tag(entry: dict[str, object], operation_id: str) -> str:
    if "tags" in entry:
        raise ValueError(
            "validation.MANUAL_TAGS_FORBIDDEN: "
            f"operation_id={operation_id!r}; field='tags' must not be set manually."
        )

    domain = entry.get("domain")
    if isinstance(domain, str) and domain.strip():
        return domain.strip()
    router_module = str(entry.get("router_module", "")).strip()
    if router_module:
        return router_module.split(".", 1)[0]
    return operation_id.split("_", 1)[0]


def _resolve_security(entry: dict[str, object]) -> list[dict[str, list[str]]] | None:
