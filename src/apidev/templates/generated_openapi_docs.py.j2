"""Generated by apidev. Do not edit manually."""

from .operation_map import OPERATION_MAP


def _resolve_domain_tag(entry: dict[str, object], operation_id: str) -> str:
    if "tags" in entry:
        raise ValueError(
            "validation.MANUAL_TAGS_FORBIDDEN: "
            f"operation_id={operation_id!r}; field='tags' must not be set manually."
        )

    domain = entry.get("domain")
    if isinstance(domain, str) and domain.strip():
        return domain.strip()
    router_module = str(entry.get("router_module", "")).strip()
    if router_module:
        return router_module.split(".", 1)[0]
    return operation_id.split("_", 1)[0]


def _resolve_security(entry: dict[str, object]) -> list[dict[str, list[str]]] | None:
    auth_mode = str(entry.get("auth", "public")).strip().lower()
    if auth_mode == "public":
        return None
    if auth_mode == "bearer":
        return [{"bearerAuth": []}]
    return [{"apidevAuth": []}]


def _build_responses(entry: dict[str, object]) -> dict[str, dict[str, object]]:
    response_schema = entry.get("response_schema", {})
    response_example = entry.get("response_example")
    response_status = str(int(entry.get("response_status", 200)))
    responses: dict[str, dict[str, object]] = {
        response_status: {
            "description": "Success",
            "content": {
                "application/json": {
                    "schema": response_schema,
                    "example": response_example,
                }
            },
        }
    }
    raw_errors = entry.get("error_schemas", [])
    if isinstance(raw_errors, list):
        sorted_errors = sorted(
            (error for error in raw_errors if isinstance(error, dict)),
            key=lambda error: (int(error.get("http_status", 500)), str(error.get("code", ""))),
        )
        for error in sorted_errors:
            status = str(int(error.get("http_status", 500)))
            code = str(error.get("code", "")).strip()
            responses[status] = {
                "description": code or f"HTTP {status}",
                "content": {
                    "application/json": {
                        "schema": error.get("body", {}),
                        "example": error.get("example"),
                    }
                },
            }
    return responses


def _build_parameters_from_fragment(
    schema_fragment: object,
    *,
    location: str,
    required_by_default: bool,
) -> list[dict[str, object]]:
    if not isinstance(schema_fragment, dict):
        return []
    properties = schema_fragment.get("properties")
    if not isinstance(properties, dict):
        return []

    parameters: list[dict[str, object]] = []
    for name in sorted(properties):
        raw_schema = properties.get(name)
        if not isinstance(raw_schema, dict):
            continue
        required = required_by_default or raw_schema.get("required") is True
        parameters.append(
            {
                "name": name,
                "in": location,
                "required": required,
                "schema": dict(raw_schema),
            }
        )
    return parameters


def _build_request_parameters(entry: dict[str, object]) -> list[dict[str, object]]:
    request = entry.get("request")
    if not isinstance(request, dict):
        return []
    return [
        *_build_parameters_from_fragment(
            request.get("path"),
            location="path",
            required_by_default=True,
        ),
        *_build_parameters_from_fragment(
            request.get("query"),
            location="query",
            required_by_default=False,
        ),
    ]


def _build_request_body(entry: dict[str, object]) -> dict[str, object] | None:
    request = entry.get("request")
    if not isinstance(request, dict):
        return None
    body_schema = request.get("body")
    if not isinstance(body_schema, dict) or not body_schema:
        return None
    return {
        "content": {
            "application/json": {
                "schema": body_schema,
            }
        }
    }


def build_openapi_paths() -> dict[str, dict[str, dict[str, object]]]:
    """Build deterministic OpenAPI `paths` fragment from generated operation metadata."""
    paths: dict[str, dict[str, dict[str, object]]] = {}
    for operation_id in sorted(OPERATION_MAP):
        entry = dict(OPERATION_MAP[operation_id])
        path = str(entry["path"])
        method = str(entry["method"]).lower()
        security = _resolve_security(entry)
        operation = {
            "operationId": operation_id,
            "description": str(entry.get("description", "")),
            "deprecated": str(entry.get("deprecation_status", "active")) == "deprecated",
            "tags": [_resolve_domain_tag(entry, operation_id)],
            "responses": _build_responses(entry),
{% if include_extensions %}
            "x-apidev-auth": str(entry.get("auth", "public")),
            "x-apidev-deprecation": {
                "status": str(entry.get("deprecation_status", "active")),
                "deprecated_since_release": entry.get("deprecated_since_release"),
            },
            "x-apidev-errors": [
                {
                    "code": str(error.get("code", "")),
                    "http_status": int(error.get("http_status", 500)),
                    "schema": error.get("body", {}),
                    "example": error.get("example"),
                }
                for error in entry.get("error_schemas", [])
            ],
{% endif %}
        }
        if security is not None:
            operation["security"] = security
        parameters = _build_request_parameters(entry)
        if parameters:
            operation["parameters"] = parameters
        request_body = _build_request_body(entry)
        if request_body is not None:
            operation["requestBody"] = request_body
        methods = paths.setdefault(path, {})
        methods[method] = operation
    return paths
