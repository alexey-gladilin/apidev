"""Manual integration scaffold: build runtime routes from generated operation map.

Adapter contract: {{ runtime_router_adapter }}
"""

import importlib
from collections.abc import Awaitable, Callable, Mapping
from dataclasses import dataclass
from typing import Any, cast

from .auth_registry import resolve_auth_dependency
from .handler_registry import resolve_handler

GENERATED_API_PACKAGE = "api"


def _import_generated_module(module_name: str) -> Any:
    try:
        return importlib.import_module(module_name)
    except ModuleNotFoundError:
        return importlib.import_module(f"{GENERATED_API_PACKAGE}.{module_name}")


_openapi_docs_module = _import_generated_module("openapi_docs")
build_openapi_components = cast(
    Callable[[], dict[str, dict[str, object]]],
    getattr(_openapi_docs_module, "build_openapi_components"),
)
build_openapi_paths = cast(
    Callable[[], dict[str, dict[str, dict[str, object]]]],
    getattr(_openapi_docs_module, "build_openapi_paths"),
)
_operation_map_module = _import_generated_module("operation_map")
OPERATION_MAP = cast(
    dict[str, Mapping[str, object]],
    getattr(_operation_map_module, "OPERATION_MAP"),
)

try:
    from fastapi import APIRouter, Depends
except ModuleNotFoundError:  # pragma: no cover - fallback for scaffold tests without FastAPI.
    @dataclass
    class _Dependency:
        dependency: Any

    @dataclass
    class _Route:
        path: str
        endpoint: Callable[..., Awaitable[Any]]
        methods: set[str]
        operation_id: str | None
        description: str | None
        deprecated: bool
        responses: dict[int, dict[str, object]]
        tags: list[str] | None
        dependencies: list[_Dependency]

    class APIRouter:  # type: ignore[no-redef]
        def __init__(self) -> None:
            self.routes: list[_Route] = []

        def add_api_route(
            self,
            path: str,
            endpoint: Callable[..., Awaitable[Any]],
            *,
            methods: list[str],
            operation_id: str | None = None,
            description: str | None = None,
            deprecated: bool = False,
            responses: dict[int, dict[str, object]] | None = None,
            tags: list[str] | None = None,
            dependencies: list[_Dependency] | None = None,
        ) -> None:
            self.routes.append(
                _Route(
                    path=path,
                    endpoint=endpoint,
                    methods={method.upper() for method in methods},
                    operation_id=operation_id,
                    description=description,
                    deprecated=deprecated,
                    responses=responses or {},
                    tags=tags,
                    dependencies=dependencies or [],
                )
            )

    def Depends(dependency: Any) -> _Dependency:  # type: ignore[no-redef]
        return _Dependency(dependency=dependency)


def _require_string(meta: Mapping[str, object], operation_id: str, key: str) -> str:
    value = meta.get(key)
    if not isinstance(value, str) or not value.strip():
        raise ValueError(f"Invalid operation metadata for '{operation_id}': '{key}' must be non-empty string.")
    return value


def _optional_string(meta: Mapping[str, object], key: str) -> str | None:
    value = meta.get(key)
    if value is None:
        return None
    if not isinstance(value, str):
        value = str(value)
    stripped = value.strip()
    return stripped or None


def _build_responses(meta: Mapping[str, object]) -> dict[int, dict[str, object]]:
    status_raw = meta.get("response_status", 200)
    try:
        success_status = int(status_raw)
    except (TypeError, ValueError) as exc:
        raise ValueError(f"Invalid operation metadata: response_status={status_raw!r}") from exc

    responses: dict[int, dict[str, object]] = {
        success_status: {"description": "Success"},
    }
    raw_errors = meta.get("error_schemas", [])
    if isinstance(raw_errors, list):
        for error_item in sorted(
            (item for item in raw_errors if isinstance(item, Mapping)),
            key=lambda item: (int(item.get("http_status", 500)), str(item.get("code", ""))),
        ):
            http_status = int(error_item.get("http_status", 500))
            code = str(error_item.get("code", "")).strip()
            responses[http_status] = {"description": code or f"HTTP {http_status}"}
    return responses


def _resolve_domain_tag(meta: Mapping[str, object], operation_id: str, router_module: str) -> str:
    if "tags" in meta:
        raise ValueError(
            "validation.MANUAL_TAGS_FORBIDDEN: "
            f"operation_id={operation_id!r}; field='tags' must not be set manually."
        )

    domain = meta.get("domain")
    if isinstance(domain, str) and domain.strip():
        return domain.strip()
    if router_module.strip():
        return router_module.split(".", 1)[0]
    return operation_id.split("_", 1)[0]


def _load_generated_route(router_module: str) -> Callable[..., Awaitable[Any]]:
    try:
        module = importlib.import_module(router_module)
    except ModuleNotFoundError:
        module = importlib.import_module(f"{GENERATED_API_PACKAGE}.{router_module}")
    route_callable = getattr(module, "route", None)
    if not callable(route_callable):
        raise ValueError(f"Generated router module '{router_module}' does not expose callable 'route'.")
    return route_callable


def _mapping_or_empty(value: object) -> dict[str, object]:
    if not isinstance(value, Mapping):
        return {}
    return dict(value)


def assemble_openapi_schema(
    base_schema: Mapping[str, object] | None = None,
) -> dict[str, object]:
    schema = dict(base_schema or {})
    schema["paths"] = build_openapi_paths()

    merged_components = _mapping_or_empty(schema.get("components"))
    merged_schemas = _mapping_or_empty(merged_components.get("schemas"))
    merged_schemas.update(build_openapi_components())
    merged_components["schemas"] = merged_schemas
    schema["components"] = merged_components
    return schema


def install_openapi(app: Any) -> None:
    from fastapi.openapi.utils import get_openapi

    def custom_openapi() -> dict[str, object]:
        cached_schema = getattr(app, "openapi_schema", None)
        if isinstance(cached_schema, dict):
            return cached_schema

        base_schema = get_openapi(
            title=str(getattr(app, "title", "")),
            version=str(getattr(app, "version", "")),
            routes=getattr(app, "routes", []),
        )
        assembled_schema = assemble_openapi_schema(base_schema)
        app.openapi_schema = assembled_schema
        return assembled_schema

    app.openapi = custom_openapi


def build_router() -> APIRouter:
    router = APIRouter()
    for operation_id in sorted(OPERATION_MAP):
        raw_meta = OPERATION_MAP[operation_id]
        if not isinstance(raw_meta, Mapping):
            raise ValueError(
                f"Invalid operation metadata for '{operation_id}': operation entry must be object."
            )
        meta = dict(raw_meta)
        method = _require_string(meta, operation_id, "method").upper()
        path = _require_string(meta, operation_id, "path")
        router_module = _require_string(meta, operation_id, "router_module")
        auth_mode = str(meta.get("auth", "public"))

        handler = resolve_handler(operation_id)
        auth_dependency = resolve_auth_dependency(auth_mode)
        dependencies = [Depends(auth_dependency)] if auth_dependency is not None else []
        async def endpoint(
            payload: Mapping[str, object] | None = None,
            current_user: Any = None,
            *,
            _meta: Mapping[str, object] = meta,
            _handler: Any = handler,
        ) -> Any:
            resolved_router_module = str(_meta["router_module"])
            route_callable = _load_generated_route(resolved_router_module)
            result = await invoke_route_with_context(
                route_callable=route_callable,
                handler=_handler,
                payload=payload,
                current_user=current_user,
            )
            return getattr(result, "payload", None) or {}

        router.add_api_route(
            path,
            endpoint,
            methods=[method],
            operation_id=operation_id,
            description=_optional_string(meta, "description"),
            deprecated=str(meta.get("deprecation_status", "active")) == "deprecated",
            responses=_build_responses(meta),
            tags=[_resolve_domain_tag(meta, operation_id, router_module)],
            dependencies=dependencies,
        )
    return router


def enrich_payload_with_user_context(
    payload: Mapping[str, object] | None,
    *,
    current_user: Any = None,
) -> dict[str, object]:
    enriched_payload = dict(payload or {})
    # Trust boundary: user context must come only from the integration layer argument.
    enriched_payload.pop("current_user", None)
    if current_user is not None:
        enriched_payload["current_user"] = current_user
    return enriched_payload


async def invoke_route_with_context(
    *,
    route_callable: Callable[..., Awaitable[Any]],
    handler: Any,
    payload: Mapping[str, object] | None,
    current_user: Any = None,
) -> Any:
    enriched_payload = enrich_payload_with_user_context(payload, current_user=current_user)
    return await route_callable(payload=enriched_payload, handler=handler)
